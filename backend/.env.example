PORT=4000
# Set to "production" on your live server (enables Secure cookies + trust proxy)
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/invoiceforge

# Auth token secrets. Generate strong unique values for production with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Encrypts secrets at rest (e.g. 2FA secrets). 32-byte hex recommended:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Auth cookies.
#  - Same root domain (app.x.com + api.x.com): leave defaults (lax).
#  - Cross-site (e.g. *.vercel.app + *.onrender.com): set COOKIE_SAMESITE=none
#    (forces Secure). Optionally set COOKIE_DOMAIN=.yourdomain.com.
COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.yourdomain.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional platform commission on connected-account payments, e.g. 1 = 1%.
# Leave 0 so businesses keep 100% of each payment.
PLATFORM_FEE_PERCENT=0

# Base URL of the frontend (used for Stripe Checkout redirect URLs + CORS)
FRONTEND_URL=http://localhost:3000

# Public base URL of this backend (used for the email "Pay Now" redirect link)
API_URL=http://localhost:4000

# Email (SMTP). If left blank, sent invoices log the pay link to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=InvoiceForge <no-reply@invoiceforge.local>

# Google Sign-In (OAuth ID token verification — client ID only, no secret needed)
GOOGLE_CLIENT_ID=
